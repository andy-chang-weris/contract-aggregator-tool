# Copy this file to .env for local/Codex runs. Do not put real keys in this
# example file.

# Data source: auto, db, dump, or sample.
RAG_DATA_SOURCE=auto
RAG_INDEX_PATH=.rag_index/index.json
RAG_DUMP_PATH=contracts.sql
RAG_TOP_K=5
RAG_MIN_SCORE=0.01
RAG_DB_LIMIT=5000

# Offline-safe default retrieval. Use sentence-transformers only when the
# dependency and model cache/network are available.
RAG_EMBEDDING_PROVIDER=hash
RAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Existing application PostgreSQL settings. The agent only performs read-only
# SELECT queries against postings.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=govcontracts
DB_USER=postgres
DB_PASSWORD=

# Generation provider:
# - mock: no network, deterministic tests
# - openai: official OpenAI chat completions endpoint
# - openai-compatible: provider exposing /chat/completions
# - ollama: reachable Ollama server
RAG_LLM_PROVIDER=mock
RAG_LLM_MODEL=mock-contract-rag
RAG_LLM_BASE_URL=
RAG_LLM_API_KEY=

RAG_TEMPERATURE=0.2
RAG_MAX_TOKENS=900
RAG_REQUEST_TIMEOUT=60
