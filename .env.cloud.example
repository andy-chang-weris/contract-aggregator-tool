# Cloud/Codex example configuration. Do not commit real credentials.

# Keep this as sample or auto for setup validation. Use db only when DB_* points
# at a reachable PostgreSQL instance.
RAG_DATA_SOURCE=sample
RAG_INDEX_PATH=.rag_index/index.json
RAG_DUMP_PATH=contracts.sql
RAG_TOP_K=5
RAG_MIN_SCORE=0.01
RAG_DB_LIMIT=5000

# Offline-safe default. Set RAG_INSTALL_EMBEDDINGS=1 before running
# setup_codex_cloud.sh if you want sentence-transformers installed too.
RAG_EMBEDDING_PROVIDER=hash
RAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Existing application PostgreSQL settings. Required only for RAG_DATA_SOURCE=db.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=govcontracts
DB_USER=postgres
DB_PASSWORD=

# Strong open-source model through a cloud provider exposing OpenAI-compatible
# /chat/completions. Examples: Qwen 32B/72B Instruct, Llama 70B Instruct,
# Mixtral-class instruct models.
RAG_LLM_PROVIDER=openai-compatible
RAG_LLM_BASE_URL=https://your-provider.example/v1
RAG_LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
RAG_LLM_API_KEY=

RAG_TEMPERATURE=0.2
RAG_MAX_TOKENS=900
RAG_REQUEST_TIMEOUT=60
